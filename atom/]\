import random
from atom.engine import Scalar
class Neuron:
    def __init__(self, nin):
        self.w = [Scalar(random.uniform(-1, 1)) for _ in range(nin)]
        self.b = Scalar(random.uniform(-1,1))
    def __call__(self, x):
        z = sum([xi * wi for xi, wi in zip(x,  self.w)]) + self.b
        return z.relu()


x = [2.0, 3.0]
n = Neuron(2)
print(n(x))
